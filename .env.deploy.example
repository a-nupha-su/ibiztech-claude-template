# .env.deploy — copy to .env.deploy and fill in (DO NOT COMMIT)
# Used by scripts/deploy.sh and auto-pipeline skill

# Required for all targets ---------------------------------------------------
DEPLOY_TARGET=vercel          # vercel | docker | gh-actions | ssh
DEPLOY_URL=https://app.example.com   # for post-deploy health check (curl 200)

# --- vercel ---
VERCEL_TOKEN=                 # from https://vercel.com/account/tokens

# --- docker ---
DOCKER_IMAGE=registry.example.com/app:latest
K8S_DEPLOYMENT=               # optional: trigger kubectl rollout restart
K8S_NAMESPACE=                # optional: namespace for kubectl

# --- gh-actions ---
GH_WORKFLOW=deploy.yml        # workflow filename in .github/workflows/
GH_REF=main                   # branch/ref to dispatch on

# --- ssh ---
SSH_HOST=user@host.example.com
SSH_PATH=/srv/app
SSH_RESTART_CMD=sudo systemctl restart app
