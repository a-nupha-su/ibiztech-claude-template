# JMeter Performance Budget — Pass/Fail thresholds
# ปรับค่าให้เหมาะกับ project แล้ว push — workflow จะอ่านไฟล์นี้

# Latency (ms) — fail ถ้า p95 > MAX
P95_MAX_MS=500
P99_MAX_MS=1000
AVG_MAX_MS=300

# Error rate (%) — fail ถ้า error > MAX
ERROR_RATE_MAX=1.0

# Throughput (req/sec) — fail ถ้า ต่ำกว่า MIN (optional, ตั้ง 0 = ไม่ check)
THROUGHPUT_MIN_RPS=0
